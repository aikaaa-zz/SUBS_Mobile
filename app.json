{
  "expo": {
    "name": "SUBS Mobile",
    "slug": "subs-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/subs-icon.png",
    "userInterfaceStyle": "light",
    "scheme": "subs-mobile",
    "splash": {
      "backgroundColor": "#ff6600"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.subs.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ff6600"
      },
      "package": "com.subs.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/subs-icon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
